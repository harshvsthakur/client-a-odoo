<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Task form: show the template-seeded planned start/end dates -->
    <record id="view_task_form2_planned_dates" model="ir.ui.view">
        <field name="name">project.task.form.planned.dates</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='date_deadline_and_recurring_task']" position="after">
                <label for="planned_date_start" string="Planned Dates"/>
                <div class="d-inline-flex w-100">
                    <field name="planned_date_start" nolabel="1"/>
                    <span class="mx-2"> - </span>
                    <field name="planned_date_end" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Task list: optional columns, off by default like most secondary dates here -->
    <record id="view_task_tree2_planned_dates" model="ir.ui.view">
        <field name="name">project.task.list.planned.dates</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <field name="date_deadline" position="after">
                <field name="planned_date_start" optional="hide"/>
                <field name="planned_date_end" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>
