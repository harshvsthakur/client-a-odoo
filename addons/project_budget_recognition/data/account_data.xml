<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Dedicated accounts for revenue-recognition journal entries, kept separate from
            normal AR/AP and sales activity (per explicit decision on TCK-10: reuse of the
            generic COA's existing Receivable/Product Sales accounts was considered and
            rejected so recognition entries stay cleanly separable).
        -->
        <record id="account_unbilled_receivable_wip" model="account.account">
            <field name="name">Unbilled Receivable / WIP (Revenue Recognition)</field>
            <field name="code">121200</field>
            <field name="account_type">asset_current</field>
            <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
        </record>

        <record id="account_recognized_revenue" model="account.account">
            <field name="name">Recognized Revenue (Project)</field>
            <field name="code">400900</field>
            <field name="account_type">income</field>
            <field name="company_ids" eval="[(6, 0, [ref('base.main_company')])]"/>
        </record>

        <record id="sequence_revenue_recognition" model="ir.sequence">
            <field name="name">Revenue Recognition</field>
            <field name="prefix">REVREC/</field>
            <field name="padding">5</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="journal_revenue_recognition" model="account.journal">
            <field name="name">Revenue Recognition</field>
            <field name="code">REVREC</field>
            <field name="type">general</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="sequence" eval="20"/>
        </record>

    </data>
</odoo>
