<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project.open_view_project_all" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_project_form_sale_order_ux" model="ir.ui.view">
        <field name="name">project.project.form.sale.order.ux</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <field name="sale_order_id" invisible="1"/>
                <button class="oe_stat_button" type="object" name="action_view_sale_order_ux" icon="fa-usd" invisible="not sale_order_id" groups="sales_team.group_sale_salesman">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Sales Order</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>
